    <rdfs:label xml:lang="zh">值类型</rdfs:label>
    <rdfs:range rdf:resource="&xsd;string" />
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="&std;versionNumber">
    <rdf:type rdf:resource="&rdf;Property" />
    <rdf:type rdf:resource="&owl;FunctionalProperty" />
    <rdfs:comment xml:lang="zh">标准的版本号。</rdfs:comment>
    <rdfs:domain rdf:resource="&std;Version" />
    <rdfs:label xml:lang="zh">版本号</rdfs:label>
    <rdfs:range rdf:resource="&xsd;string" />
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="&std;versionStatus">
    <rdf:type rdf:resource="&rdf;Property" />
    <rdfs:comment xml:lang="zh">版本的当前状态。</rdfs:comment>
    <rdfs:domain rdf:resource="&std;Version" />
    <rdfs:label xml:lang="zh">版本状态</rdfs:label>
    <rdfs:range rdf:resource="&xsd;string" />
  </owl:DatatypeProperty>
</rdf:RDF>